{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": "off",
    "disown-opener": "off",
    "no-inline-styles": "off",
    "css-prefix-order": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "ime-mode"
        ]
      }
    ]
  }
}